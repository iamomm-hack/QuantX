# Backend API port
PORT=3001

# Stellar RPC URL
RPC_URL=https://soroban-testnet.stellar.org

# Contract ID (deploy contract first)
CONTRACT_ID=YOUR_CONTRACT_ID_HERE

# Executor secret key (testnet only - NEVER use in production)
EXECUTOR_SECRET=YOUR_EXECUTOR_SECRET_KEY_HERE

# Execution configuration
CHECK_INTERVAL=10000

# API configuration
API_KEY=your_api_key_here
ENABLE_WEBHOOKS=false
WEBHOOK_URL=https://your-webhook-endpoint.com/webhook

# Database (optional - for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/payfluxx

# Notifications (optional)
# SENDGRID_API_KEY=your_sendgrid_key
# NOTIFICATION_EMAIL=notifications@payfluxx.com
