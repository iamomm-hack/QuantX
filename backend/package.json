{
  "name": "quantx-backend",
  "version": "1.0.0",
  "description": "Backend API and executor for QuantX recurring payments",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "executor": "node executor.js",
    "dev:executor": "nodemon executor.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:executor\""
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "mongoose": "^9.1.5",
    "quantx-sdk": "file:../quantx-sdk"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "nodemon": "^3.0.0"
  }
}
