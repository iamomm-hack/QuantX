{
  "name": "quantx-sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for QuantX Decentralized Payments",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "stellar",
    "soroban",
    "payments",
    "sdk"
  ],
  "author": "QuantX",
  "license": "MIT",
  "dependencies": {
    "@stellar/stellar-sdk": "^14.4.3",
    "bignumber.js": "^9.1.2"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.2"
  },
  "publishConfig": {
    "access": "public"
  }
}